---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <BaseHead title={title} />
  <body>

    <Nav />

  <div class="container">
    <main role="main">
      <h1 class="display-4"> {title}</h1>

  <slot />
    </main>
  </div>
      <Footer />



  </body>
</html>
