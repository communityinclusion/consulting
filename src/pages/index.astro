---
import FrontLayout from '../layouts/FrontLayout.astro';
import StaffTeaser from '../components/StaffTeaser.astro';
import AreaTeaser from '../components/AreaTeaser.astro';
import Testimonial from '../components/Testimonial.astro';
import { getCollection } from 'astro:content';

const allStaff = await getCollection('staff');
const allAreas = await getCollection('areas');

// Staff order matching the original homepage layout
const staffOrder = ['alvaro', 'hoff', 'jaimie', 'jeff', 'jenn', 'joe', 'john', 'julisa', 'linda', 'neil', 'russ', 'vito', 'lara', 'cee', 'cindy', 'melissa', 'allison', 'kelly'];

const orderedStaff = staffOrder.map(slug => allStaff.find(s => s.id === slug)).filter(Boolean);

// Area order matching the original homepage layout
const areaOrder = ['vr', 'provider', 'a11y', 'media'];
const orderedAreas = areaOrder.map(slug => allAreas.find(a => a.id === slug)).filter(Boolean);

// Split staff into rows of 3
const staffRows: typeof orderedStaff[] = [];
for (let i = 0; i < orderedStaff.length; i += 3) {
  staffRows.push(orderedStaff.slice(i, i + 3));
}
---

<FrontLayout>
<div class="jumbotron-blue">
  <div class="container">
      <div class="row">
          <div class="col-lg-9"> <img src="/imgs/icisq.png"  alt="ICI logo" class="logo" style="">
            <h1>ICI CONSULTING </h1>
            <h3>Decades of problem-solving experience.</h3>

            <div class="clearfix"></div>
            <br>
            <p class="lead">The Institute for Community Inclusion, or ICI, is nationally recognized for our research, technical
