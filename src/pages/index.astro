      </div>

    </div>
    <p></p>
    <div class="row">
<div class="col-lg">
        <AreaTeaser slug="a11y" teaserTitle={orderedAreas[2]!.data.teaserTitle} teaserDescription={orderedAreas[2]!.data.teaserDescription} />

